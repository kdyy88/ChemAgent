# ╔══════════════════════════════════════════════════════════════════╗
# ║           ChemAgent — Unified Environment Variables             ║
# ║              Copy this file to .env and fill in values.         ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# This single file is the source of truth for:
#   • Local dev  →  dev.sh sources it and exports all vars to every process
#   • Docker     →  compose.yaml reads it via env_file / ${VAR:-default}
#
# NEVER commit the real .env — it is listed in .gitignore.

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Required. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Set to a custom OpenAI-compatible base URL (e.g. a proxy / relay).
OPENAI_BASE_URL=

# Optional. Override the default chat model. Defaults to gpt-4o if blank.
OPENAI_MODEL=

# Optional. Fast/cheap model for internal routing decisions. Defaults to OPENAI_MODEL.
FAST_MODEL=

# ── Search ────────────────────────────────────────────────────────────────────
# Optional. Required only if you use the web_search tool.
# Get a key at https://serper.dev
SERPER_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: keep the default below (./dev.sh starts a local redis-server).
# Docker   : compose.yaml overrides this to redis://redis:6379/0 automatically.
REDIS_URL=redis://127.0.0.1:6379/0

# ── Backend / Worker ──────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# Maximum number of concurrent agent jobs the ARQ worker will process.
CHEMAGENT_WORKER_MAX_JOBS=2

# Hard timeout (seconds) for a single agent job before it is killed.
CHEMAGENT_WORKER_JOB_TIMEOUT_SECONDS=120

# How often (seconds) the API polls Redis for task results.
TASK_POLL_INTERVAL_SECONDS=0.2

# How long (seconds) task results are kept in Redis before expiry.
TASK_RESULT_TTL_SECONDS=300

# How long (seconds) generated artifacts (images, SDF files, …) live in Redis.
ARTIFACT_TTL_SECONDS=300

# ── Frontend (local dev only) ──────────────────────────────────────────────────
# These are exported by dev.sh so Next.js picks them up via process env.
# In Docker, nginx transparently routes /api and /ws — do not set these there.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3030
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3030
