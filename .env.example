OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# Web search (Serper — https://serper.dev)
SERPER_API_KEY=your_serper_api_key_here

# Public browser origin used by CORS / WebSocket origin checks.
# Replace with your real domain or server IP before deployment.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Optional: when empty, the frontend uses same-origin WebSocket access through nginx.
# Only set this if you explicitly want the browser to connect to another backend origin.
NEXT_PUBLIC_WS_URL=